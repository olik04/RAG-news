# RAG-news Environment Configuration
# Copy this file to .env and fill in the values for your deployment

# === LLM PROVIDERS ===
# At least one LLM provider must be configured for the system to work
# The system attempts fallback in order: Google → Groq → Mistral → Heuristics

GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-2.5-pro

GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

MISTRAL_API_KEY=
MISTRAL_GRADER_MODEL=mistral-large-latest
MISTRAL_REWRITER_MODEL=mistral-large-latest

# === SEARCH & DATA ===
# Tavily provides real-time web search context; optional but recommended
TAVILY_API_KEY=

# === DATABASE & PERSISTENCE ===
CHROMA_PATH=./data/chroma

# Collection naming: default derived from EMBEDDING_BACKEND + EMBEDDING_MODEL below
# Override only if managing multiple independent collections
# Default example: sentinel_news_semantic_all-MiniLM-L6-v2
# CHROMA_COLLECTION_NAME=sentinel_news

# === EMBEDDING CONFIGURATION (Phase 3) ===
# EMBEDDING_BACKEND: Choose retrieval strategy
#   - "semantic" (default): Uses sentence-transformers for meaning-aware retrieval
#   - "hash": Legacy hash-based embeddings (not recommended, use only for migration)
EMBEDDING_BACKEND=semantic

# EMBEDDING_MODEL: Sentence-transformers model for semantic embeddings
# Options:
#   - all-MiniLM-L6-v2 (default): 22 MB, fast, good quality
#   - bge-small-en-v1.5: 33 MB, slower, better quality
#   - sentence-transformers/all-mpnet-base-v2: 428 MB, slowest, excellent quality
EMBEDDING_MODEL=all-MiniLM-L6-v2

# === RETRIEVAL & GRADING ===
MIN_RELEVANCE_SCORE=0.45
MAX_RETRIEVAL_ATTEMPTS=2
LOCAL_TOP_K=5
WEB_TOP_K=5
NEWS_DAYS_BACK=1

# === DATA RETENTION ===
# Automatically purge documents older than this many days on scheduler runs
NEWS_RETENTION_DAYS=30
NEWS_RETENTION_ENABLED=true
PURGE_HOUR=2
PURGE_MINUTE=0
PURGE_BATCH_SIZE=500

# === DISTRIBUTION & SCHEDULING ===
# Timezone must be IANA format (Asia/Hong_Kong, US/Eastern, etc.)
NEWS_TIMEZONE=Asia/Hong_Kong

# Daily digest timing (24-hour format)
DIGEST_HOUR=9
DIGEST_MINUTE=0

# Query for daily digest generation
NEWS_DAILY_QUERY=latest geopolitical developments last 24 hours

# === TELEGRAM INTEGRATION ===
# Both required for Telegram bot to function
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# === HTTP API CONFIGURATION ===
HTTP_HOST=0.0.0.0
HTTP_PORT=8000

# Optional: Bearer token for API authentication
# If set, all requests require: Authorization: Bearer {HTTP_API_KEY}
# Leave empty to allow unauthenticated access
HTTP_API_KEY=

# === API & EXTERNAL SERVICE SETTINGS (Phase 3) ===

# Maximum character length for user questions (prevents abuse)
MAX_QUESTION_LENGTH=1000

# Rate limit: requests per minute per client (IP for API, chat_id for bot)
MAX_REQUESTS_PER_MINUTE=20

# External API call timeout in seconds
API_TIMEOUT_SECONDS=5.0

# Number of retry attempts for transient API failures
API_MAX_RETRIES=3

# Exponential backoff multiplier (must be >= 1.0)
# Retry delay formula: base_delay × (backoff_factor ^ attempt)
# With default 2.0: attempt 1 waits 1s, attempt 2 waits 2s, attempt 3 waits 4s
API_BACKOFF_FACTOR=2.0

# Jitter factor for retry delays (0.0 to 1.0)
# Prevents thundering herd in distributed deployments
# Actual delay = calculated_delay ± (jitter_factor × calculated_delay)
API_JITTER_FACTOR=0.1

# Optional overrides for LLM provider calls (fall back to API_* when unset)
# LLM_API_TIMEOUT_SECONDS=6.0
# LLM_API_MAX_RETRIES=2
# LLM_API_BACKOFF_FACTOR=2.0
# LLM_API_JITTER_FACTOR=0.1

# Optional overrides for Tavily calls (fall back to API_* when unset)
# TAVILY_API_TIMEOUT_SECONDS=4.0
# TAVILY_API_MAX_RETRIES=3
# TAVILY_API_BACKOFF_FACTOR=2.0
# TAVILY_API_JITTER_FACTOR=0.1

# Scheduler digest retry loop (outer retry around the end-to-end digest send)
SCHEDULER_DIGEST_MAX_RETRIES=3
SCHEDULER_DIGEST_BACKOFF_SECONDS=2.0

# === LOGGING ===
LOG_LEVEL=INFO
